{
  "compilerOptions": {
    "target": "ES2023", "module": "ESNext", "lib": ["ES2023", "DOM"],
    "moduleResolution": "bundler", "verbatimModuleSyntax": true,
    "moduleDetection": "force", "resolveJsonModule": true, "noEmit": true,
    "strict": true, "skipLibCheck": true,
    "noUnusedLocals": true, "noUnusedParameters": true,
    "erasableSyntaxOnly": true, "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true, "types": ["node"]
  },
  "include": ["main.ts"],
  "exclude": ["dist", "serve.ts"]
}
